# .env.example
# This file shows all environment variables needed for Paper Digest
# 
# ⚠️  IMPORTANT - For Railway/Render Deployment:
#     Only set: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GITHUB_CLIENT_ID, 
#     GITHUB_CLIENT_SECRET, SENDGRID_API_KEY, SECRET_KEY, APP_URL
#     
#     DO NOT set REDIRECT_URIs in Railway - they're auto-generated from APP_URL
#     Instead, add redirect URIs in Google Cloud Console and GitHub OAuth settings

# ── OAuth - Google ────────────────────────────────────────────
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# For local dev only:
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# ── OAuth - GitHub ────────────────────────────────────────────
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# For local dev only:
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback/github

# ── App Configuration ────────────────────────────────────────
# For local dev, keep as-is. For production, set to your domain
APP_URL=http://localhost:8000
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
# User can provide their own, or set a default for global use
GROQ_API_KEY=your-groq-api-key

# ── SendGrid Configuration ──────────────────────────────────
# Get from: https://sendgrid.com (Settings → API Keys)
# Must be verified sender in SendGrid first
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@paperdigest.ai

# ── Deployment ──────────────────────────────────────────────
# For production, update APP_URL to match your domain:
# APP_URL=https://paperdigest.yourcompany.com
