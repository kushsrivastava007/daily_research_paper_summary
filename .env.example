# .env.example
# This file shows all environment variables needed for Paper Digest

# ── OAuth - Google ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# ── OAuth - GitHub ────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback/github

# ── App Configuration ────────────────────────────────────────
APP_URL=http://localhost:8000
SECRET_KEY=your-secret-key-change-in-production
GROQ_API_KEY=your-groq-api-key

# ── SendGrid Configuration ──────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@paperdigest.ai

# ── Deployment ──────────────────────────────────────────────
# For production, set APP_URL to your domain:
# APP_URL=https://paperdigest.yourcompany.com
